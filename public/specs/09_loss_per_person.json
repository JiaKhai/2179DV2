{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "width": "container",
  "height": 480,
  "data": {
    "url": "data/processed/story_state_summary.csv"
  },
  "transform": [
    {
      "calculate": "toNumber(datum.flood_loss_2025_rm_per_person)",
      "as": "loss_per_person"
    },
    {
      "calculate": "replace(datum.state, 'W.P.', 'Federal Territory')",
      "as": "display_state"
    },
    {
      "calculate": "datum.region == 'Central/Southern Peninsula' ? 'Central Peninsula' : datum.region",
      "as": "display_region"
    },
    {
      "filter": "isValid(datum.loss_per_person)"
    },
    {
      "window": [
        {
          "op": "rank",
          "as": "rank"
        }
      ],
      "sort": [
        {
          "field": "loss_per_person",
          "order": "descending"
        }
      ]
    },
    {
      "filter": "datum.rank <= 10"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadiusEnd": 3
      },
      "encoding": {
        "y": {
          "field": "display_state",
          "type": "nominal",
          "sort": [
            "Perlis",
            "Terengganu",
            "Kelantan",
            "Pahang",
            "Sarawak",
            "Federal Territory Labuan",
            "Johor",
            "Kedah",
            "Sabah",
            "Perak"
          ],
          "title": null,
          "axis": {
            "labelLimit": 160
          }
        },
        "x": {
          "field": "loss_per_person",
          "type": "quantitative",
          "title": "2025 flood loss per person (Malaysian ringgit)",
          "scale": {
            "domain": [
              0,
              180
            ]
          }
        },
        "color": {
          "field": "display_region",
          "type": "nominal",
          "title": "Region",
          "scale": {
            "domain": [
              "Borneo",
              "East Coast",
              "Northern Peninsula",
              "Southern Peninsula",
              "Central Peninsula"
            ],
            "range": [
              "#0072B2",
              "#E69F00",
              "#CC79A7",
              "#8A6F00",
              "#56B4E9"
            ]
          }
        },
        "tooltip": [
          {
            "field": "display_state",
            "type": "nominal",
            "title": "State / territory"
          },
          {
            "field": "display_region",
            "type": "nominal",
            "title": "Region"
          },
          {
            "field": "loss_per_person",
            "type": "quantitative",
            "title": "Loss per person (Malaysian ringgit)",
            "format": ",.2f"
          },
          {
            "field": "flood_total_loss_2025_rm_million",
            "type": "quantitative",
            "title": "Total loss (million Malaysian ringgit)",
            "format": ",.1f"
          }
        ]
      }
    },
    {
      "data": {
        "values": [
          {
            "state": "Perlis",
            "box_start": 108,
            "box_end": 154,
            "display_state": "Perlis"
          }
        ]
      },
      "mark": {
        "type": "rect",
        "height": 66,
        "fill": "#eef6f4",
        "stroke": "#102321",
        "strokeOpacity": 0.55,
        "cornerRadius": 4
      },
      "encoding": {
        "y": {
          "field": "display_state",
          "type": "nominal",
          "sort": [
            "Perlis",
            "Terengganu",
            "Kelantan",
            "Pahang",
            "Sarawak",
            "Federal Territory Labuan",
            "Johor",
            "Kedah",
            "Sabah",
            "Perak"
          ]
        },
        "x": {
          "field": "box_start",
          "type": "quantitative",
          "scale": {
            "domain": [
              0,
              180
            ]
          }
        },
        "x2": {
          "field": "box_end"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "state": "Perlis",
            "label_x": 110,
            "label": "Perlis ranks first\nper person despite\nmodest total loss",
            "display_state": "Perlis"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "fontSize": 10.6,
        "fontWeight": "600",
        "lineBreak": "\n",
        "lineHeight": 12.2,
        "fill": "#102321",
        "dy": -1
      },
      "encoding": {
        "y": {
          "field": "display_state",
          "type": "nominal",
          "sort": [
            "Perlis",
            "Terengganu",
            "Kelantan",
            "Pahang",
            "Sarawak",
            "Federal Territory Labuan",
            "Johor",
            "Kedah",
            "Sabah",
            "Perak"
          ]
        },
        "x": {
          "field": "label_x",
          "type": "quantitative",
          "scale": {
            "domain": [
              0,
              180
            ]
          }
        },
        "text": {
          "field": "label",
          "type": "nominal"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFontSize": 12,
      "titleFontSize": 13,
      "labelLimit": 180,
      "titleLimit": 320,
      "grid": false
    },
    "legend": {
      "orient": "bottom",
      "direction": "horizontal",
      "columns": 3,
      "labelLimit": 300,
      "titleLimit": 360,
      "labelFontSize": 12,
      "titleFontSize": 12
    }
  },
  "title": {
    "text": "2025 Flood Loss Per Person by State",
    "anchor": "start",
    "align": "left",
    "font": "Manrope",
    "fontSize": 14,
    "fontWeight": 700,
    "color": "#102321",
    "offset": 12
  }
}
