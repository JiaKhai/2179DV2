{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "width": "container",
  "height": 430,
  "data": {
    "url": "data/processed/malaysia_adm1.geojson",
    "format": {
      "type": "json",
      "property": "features"
    }
  },
  "transform": [
    {
      "calculate": "datum.properties.state",
      "as": "state"
    },
    {
      "lookup": "state",
      "from": {
        "data": {
          "url": "data/processed/story_state_summary.csv"
        },
        "key": "state",
        "fields": [
          "region",
          "flood_total_loss_2025_rm_million",
          "flood_loss_2025_rm_per_person",
          "annual_rainfall_avg_2013_2017_mm"
        ]
      }
    }
  ],
  "projection": {
    "type": "mercator"
  },
  "mark": {
    "type": "geoshape",
    "stroke": "#f7f3ea",
    "strokeWidth": 1
  },
  "encoding": {
    "color": {
      "field": "flood_total_loss_2025_rm_million",
      "type": "quantitative",
      "title": "2025 flood loss (million Malaysian ringgit)",
      "scale": {
        "range": [
          "#EAF4FA",
          "#CFE7F3",
          "#A8D4EA",
          "#73BCE0",
          "#3E9DD0",
          "#0072B2"
        ]
      },
      "legend": {
        "gradientLength": 260,
        "gradientThickness": 16
      }
    },
    "tooltip": [
      {
        "field": "state",
        "type": "nominal",
        "title": "State / territory"
      },
      {
        "field": "region",
        "type": "nominal",
        "title": "Region"
      },
      {
        "field": "flood_total_loss_2025_rm_million",
        "type": "quantitative",
        "title": "Loss (million Malaysian ringgit)",
        "format": ",.1f"
      },
      {
        "field": "flood_loss_2025_rm_per_person",
        "type": "quantitative",
        "title": "Loss per person (Malaysian ringgit)",
        "format": ",.2f"
      },
      {
        "field": "annual_rainfall_avg_2013_2017_mm",
        "type": "quantitative",
        "title": "Average annual rainfall, 2013-2017 (millimetres)",
        "format": ",.0f"
      }
    ]
  },
  "config": {
    "view": {
      "stroke": null
    },
    "legend": {
      "orient": "bottom",
      "direction": "horizontal",
      "columns": 3,
      "labelLimit": 260,
      "titleLimit": 360,
      "labelFontSize": 12,
      "titleFontSize": 12
    },
    "axis": {
      "labelFontSize": 12,
      "titleFontSize": 13,
      "labelLimit": 180,
      "titleLimit": 320
    }
  },
  "title": {
    "text": "2025 Flood Loss by State",
    "anchor": "start",
    "align": "left",
    "font": "Manrope",
    "fontSize": 14,
    "fontWeight": 700,
    "color": "#102321",
    "offset": 12
  }
}
