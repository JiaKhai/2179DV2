{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "width": "container",
  "height": 430,
  "projection": {
    "type": "mercator"
  },
  "layer": [
    {
      "data": {
        "url": "data/processed/malaysia_adm1.geojson",
        "format": {
          "type": "json",
          "property": "features"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#dfe8e1",
        "stroke": "#f7f3ea",
        "strokeWidth": 1
      }
    },
    {
      "data": {
        "url": "data/processed/rainfall_stations_mappable.csv"
      },
      "mark": {
        "type": "circle",
        "size": 9,
        "opacity": 0.48,
        "color": "#2f7ea8"
      },
      "encoding": {
        "longitude": {
          "field": "longitude",
          "type": "quantitative"
        },
        "latitude": {
          "field": "latitude",
          "type": "quantitative"
        },
        "tooltip": [
          {
            "field": "station_name",
            "type": "nominal",
            "title": "Station"
          },
          {
            "field": "state",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "station_no",
            "type": "nominal",
            "title": "Station number"
          }
        ]
      }
    },
    {
      "data": {
        "values": [
          {
            "longitude": 98.8,
            "latitude": 1.2,
            "longitude2": 100.8,
            "latitude2": 3.4
          }
        ]
      },
      "mark": {
        "type": "rule",
        "stroke": "#102321",
        "strokeWidth": 1,
        "opacity": 0.62
      },
      "encoding": {
        "longitude": {
          "field": "longitude",
          "type": "quantitative"
        },
        "latitude": {
          "field": "latitude",
          "type": "quantitative"
        },
        "longitude2": {
          "field": "longitude2"
        },
        "latitude2": {
          "field": "latitude2"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "longitude": 98.8,
            "latitude": 1.2,
            "label": "West coast cluster reflects\ndenser towns, roads, and\nflood-monitoring needs"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "font": "Manrope",
        "fontSize": 12,
        "fontWeight": 700,
        "lineBreak": "\n",
        "lineHeight": 14,
        "fill": "#102321"
      },
      "encoding": {
        "longitude": {
          "field": "longitude",
          "type": "quantitative"
        },
        "latitude": {
          "field": "latitude",
          "type": "quantitative"
        },
        "text": {
          "field": "label",
          "type": "nominal"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFontSize": 12,
      "titleFontSize": 13,
      "labelLimit": 180,
      "titleLimit": 320
    },
    "legend": {
      "orient": "bottom",
      "direction": "horizontal",
      "columns": 3,
      "labelLimit": 260,
      "titleLimit": 360,
      "labelFontSize": 12,
      "titleFontSize": 12
    }
  },
  "title": {
    "text": "Rainfall Station Network Across Malaysia",
    "anchor": "start",
    "align": "left",
    "font": "Manrope",
    "fontSize": 14,
    "fontWeight": 700,
    "color": "#102321",
    "offset": 12
  }
}
