{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "width": "container",
  "height": 480,
  "data": { "url": "data/processed/rainfall_stations_mappable.csv" },
  "transform": [
    {
      "lookup": "state",
      "from": {
        "data": { "url": "data/processed/state_lookup.csv" },
        "key": "state",
        "fields": ["region"]
      }
    },
    {
      "aggregate": [{ "op": "count", "as": "station_count" }],
      "groupby": ["state", "region"]
    }
  ],
  "mark": { "type": "bar", "cornerRadiusEnd": 3 },
  "encoding": {
    "y": {
      "field": "state",
      "type": "nominal",
      "sort": "-x",
      "title": null,
      "axis": { "labelLimit": 160 }
    },
    "x": {
      "field": "station_count",
      "type": "quantitative",
      "title": "Mappable rainfall stations"
    },
    "color": {
      "field": "region",
      "type": "nominal",
      "title": "Region",
      "scale": {
        "range": ["#2f7ea8", "#bd4a36", "#6f8f56", "#d8a448", "#8b6f96"]
      }
    },
    "tooltip": [
      { "field": "state", "type": "nominal", "title": "State / territory" },
      { "field": "region", "type": "nominal", "title": "Region" },
      { "field": "station_count", "type": "quantitative", "title": "Stations" }
    ]
  },
  "config": {
    "view": { "stroke": null },
    "axis": { "grid": false },
    "legend": { "orient": "bottom" }
  }
}
