{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "width": "container",
  "height": 430,
  "data": {
    "url": "data/processed/rainfall_area_cartogram.geojson",
    "format": { "type": "json", "property": "features" }
  },
  "transform": [
    { "calculate": "datum.properties.state", "as": "state" },
    { "calculate": "datum.properties.region", "as": "region" },
    {
      "calculate": "toNumber(datum.properties.annual_rainfall_avg_2013_2017_mm)",
      "as": "rainfall"
    },
    { "calculate": "toNumber(datum.properties.area_scale)", "as": "area_scale" },
    {
      "lookup": "state",
      "from": {
        "data": { "url": "data/processed/story_state_summary.csv" },
        "key": "state",
        "fields": ["flood_total_loss_2025_rm_million"]
      }
    }
  ],
  "projection": {
    "type": "mercator",
    "center": [109.5, 4.1],
    "scale": 3000
  },
  "mark": { "type": "geoshape", "stroke": "#f7f3ea", "strokeWidth": 1.1 },
  "encoding": {
    "color": {
      "field": "rainfall",
      "type": "quantitative",
      "title": "Avg annual rainfall, 2013-2017 (mm)",
      "scale": { "scheme": "blues" }
    },
    "tooltip": [
      { "field": "state", "type": "nominal", "title": "State / territory" },
      { "field": "region", "type": "nominal", "title": "Region" },
      { "field": "rainfall", "type": "quantitative", "title": "Avg rainfall (mm)", "format": ",.0f" },
      { "field": "area_scale", "type": "quantitative", "title": "Relative area scale", "format": ".2f" },
      {
        "field": "flood_total_loss_2025_rm_million",
        "type": "quantitative",
        "title": "2025 loss (RM million)",
        "format": ",.1f"
      }
    ]
  },
  "config": {
    "view": { "stroke": null },
    "legend": { "orient": "bottom", "direction": "horizontal" }
  }
}
