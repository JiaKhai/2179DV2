{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "width": "container",
  "height": 480,
  "data": {
    "url": "data/processed/rainfall_state_annual.csv"
  },
  "transform": [
    {
      "filter": "datum.year != '2013-2017 average'"
    },
    {
      "filter": "indexof(['Terengganu','Kelantan','Sarawak','Johor','Selangor','Pahang'], datum.state) >= 0"
    },
    {
      "calculate": "toNumber(datum.year)",
      "as": "year_number"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "line",
        "point": {
          "filled": true,
          "size": 54
        },
        "strokeWidth": 2.6
      },
      "encoding": {
        "x": {
          "field": "year_number",
          "type": "quantitative",
          "title": "Year",
          "scale": {
            "domain": [
              2013,
              2017.85
            ]
          },
          "axis": {
            "format": "d",
            "tickMinStep": 1,
            "values": [
              2013,
              2014,
              2015,
              2016,
              2017
            ]
          }
        },
        "y": {
          "field": "annual_rainfall_mm",
          "type": "quantitative",
          "title": "Annual rainfall (millimetres)",
          "scale": {
            "domain": [
              1500,
              4600
            ]
          }
        },
        "color": {
          "field": "state",
          "type": "nominal",
          "title": "State",
          "scale": {
            "domain": [
              "Terengganu",
              "Sarawak",
              "Kelantan",
              "Pahang",
              "Johor",
              "Selangor"
            ],
            "range": [
              "#0072B2",
              "#E69F00",
              "#CC79A7",
              "#56B4E9",
              "#F0E442",
              "#6B7B87"
            ]
          },
          "legend": null
        },
        "detail": {
          "field": "state"
        },
        "tooltip": [
          {
            "field": "state",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "year_number",
            "type": "quantitative",
            "title": "Year",
            "format": "d"
          },
          {
            "field": "annual_rainfall_mm",
            "type": "quantitative",
            "title": "Rainfall (millimetres)",
            "format": ",.0f"
          }
        ],
        "opacity": {
          "condition": {
            "test": "rainfallState == 'All states' || datum.state == rainfallState",
            "value": 1
          },
          "value": 0.18
        },
        "strokeWidth": {
          "condition": {
            "test": "rainfallState == 'All states' || datum.state == rainfallState",
            "value": 3
          },
          "value": 1.4
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "state": "Terengganu",
            "label_x": 2017.12,
            "label_y": 4383,
            "label": "Terengganu 4,383"
          },
          {
            "state": "Sarawak",
            "label_x": 2017.12,
            "label_y": 3810,
            "label": "Sarawak 3,727"
          },
          {
            "state": "Kelantan",
            "label_x": 2017.12,
            "label_y": 3615,
            "label": "Kelantan 3,685"
          },
          {
            "state": "Pahang",
            "label_x": 2017.12,
            "label_y": 2633,
            "label": "Pahang 2,633"
          },
          {
            "state": "Johor",
            "label_x": 2017.12,
            "label_y": 2280,
            "label": "Johor 2,278"
          },
          {
            "state": "Selangor",
            "label_x": 2017.12,
            "label_y": 2110,
            "label": "Selangor 2,185"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 4,
        "fontSize": 11.5,
        "fontWeight": "600"
      },
      "encoding": {
        "x": {
          "field": "label_x",
          "type": "quantitative",
          "scale": {
            "domain": [
              2013,
              2017.85
            ]
          }
        },
        "y": {
          "field": "label_y",
          "type": "quantitative",
          "scale": {
            "domain": [
              1500,
              4600
            ]
          }
        },
        "color": {
          "field": "state",
          "type": "nominal",
          "scale": {
            "domain": [
              "Terengganu",
              "Sarawak",
              "Kelantan",
              "Pahang",
              "Johor",
              "Selangor"
            ],
            "range": [
              "#0072B2",
              "#E69F00",
              "#CC79A7",
              "#56B4E9",
              "#F0E442",
              "#6B7B87"
            ]
          },
          "legend": null
        },
        "text": {
          "field": "label",
          "type": "nominal"
        },
        "opacity": {
          "condition": {
            "test": "rainfallState == 'All states' || datum.state == rainfallState",
            "value": 1
          },
          "value": 0.18
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFontSize": 12,
      "titleFontSize": 13,
      "labelLimit": 180,
      "titleLimit": 320,
      "gridColor": "#d8ded9"
    },
    "legend": {
      "orient": "bottom",
      "direction": "horizontal",
      "columns": 3,
      "labelLimit": 260,
      "titleLimit": 360,
      "labelFontSize": 12,
      "titleFontSize": 12
    }
  },
  "params": [
    {
      "name": "rainfallState",
      "value": "All states",
      "bind": {
        "input": "select",
        "name": "Highlight state: ",
        "options": [
          "All states",
          "Terengganu",
          "Sarawak",
          "Kelantan",
          "Pahang",
          "Johor",
          "Selangor"
        ]
      }
    }
  ],
  "title": {
    "text": "Annual Rainfall in Selected States, 2013-2017",
    "anchor": "start",
    "align": "left",
    "font": "Manrope",
    "fontSize": 14,
    "fontWeight": 700,
    "color": "#102321",
    "offset": 12
  }
}
