{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "width": "container",
  "height": 480,
  "data": { "url": "data/processed/rainfall_state_annual.csv" },
  "transform": [
    { "filter": "datum.year != '2013-2017 average'" },
    { "filter": "indexof(['Terengganu','Kelantan','Sarawak','Johor','Selangor','Pahang'], datum.state) >= 0" }
  ],
  "layer": [
    {
      "mark": { "type": "line", "point": true, "strokeWidth": 2.5 },
      "encoding": {
        "x": {
          "field": "year",
          "type": "quantitative",
          "title": "Year",
          "scale": { "domain": [2013, 2018] },
          "axis": { "format": "d", "tickMinStep": 1 }
        },
        "y": {
          "field": "annual_rainfall_mm",
          "type": "quantitative",
          "title": "Annual rainfall (mm)",
          "scale": { "zero": false }
        },
        "color": {
          "field": "state",
          "type": "nominal",
          "title": "State",
          "scale": {
            "range": ["#bd4a36", "#d87b3f", "#2f7ea8", "#6f8f56", "#8b6f96", "#5f7f92"]
          }
        },
        "tooltip": [
          { "field": "state", "type": "nominal", "title": "State" },
          { "field": "year", "type": "quantitative", "title": "Year", "format": "d" },
          {
            "field": "annual_rainfall_mm",
            "type": "quantitative",
            "title": "Rainfall (mm)",
            "format": ",.0f"
          }
        ]
      }
    },
    {
      "data": {
        "values": [
          {
            "year": 2017,
            "annual_rainfall_mm": 4382.98,
            "x2": 2016.78,
            "y2": 4383,
            "label_x": 2015.42,
            "label_y": 4425,
            "label": "Terengganu records\nthe highest rainfall here"
          }
        ]
      },
      "mark": { "type": "rule", "stroke": "#102321", "strokeWidth": 1, "opacity": 0.75 },
      "encoding": {
        "x": { "field": "year", "type": "quantitative", "scale": { "domain": [2013, 2018] } },
        "y": { "field": "annual_rainfall_mm", "type": "quantitative" },
        "x2": { "field": "x2" },
        "y2": { "field": "y2" }
      }
    },
    {
      "data": {
        "values": [
          {
            "year": 2017,
            "annual_rainfall_mm": 4382.98
          }
        ]
      },
      "mark": {
        "type": "point",
        "shape": "triangle-left",
        "filled": true,
        "size": 70,
        "fill": "#102321",
        "opacity": 0.85
      },
      "encoding": {
        "x": { "field": "year", "type": "quantitative", "scale": { "domain": [2013, 2018] } },
        "y": { "field": "annual_rainfall_mm", "type": "quantitative" }
      }
    },
    {
      "data": {
        "values": [
          {
            "box_x1": 2015.32,
            "box_x2": 2016.78,
            "box_y1": 4620,
            "box_y2": 4230,
            "label": "Terengganu records\nthe highest rainfall here"
          }
        ]
      },
      "mark": {
        "type": "rect",
        "fill": "#eef6f4",
        "stroke": "#102321",
        "strokeOpacity": 0.55,
        "cornerRadius": 4
      },
      "encoding": {
        "x": { "field": "box_x1", "type": "quantitative", "scale": { "domain": [2013, 2018] } },
        "x2": { "field": "box_x2" },
        "y": { "field": "box_y1", "type": "quantitative" },
        "y2": { "field": "box_y2" }
      }
    },
    {
      "data": {
        "values": [
          {
            "label_x": 2015.42,
            "label_y": 4425,
            "label": "Terengganu records\nthe highest rainfall here"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "fontSize": 12,
        "fontWeight": "600",
        "lineBreak": "\n",
        "lineHeight": 14,
        "fill": "#102321"
      },
      "encoding": {
        "x": { "field": "label_x", "type": "quantitative", "scale": { "domain": [2013, 2018] } },
        "y": { "field": "label_y", "type": "quantitative" },
        "text": { "field": "label", "type": "nominal" }
      }
    }
  ],
  "config": {
    "view": { "stroke": null },
    "axis": { "gridColor": "#d8ded9" },
    "legend": { "orient": "bottom" }
  }
}
